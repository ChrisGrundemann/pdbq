# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PeeringDB (authenticated access)
PEERINGDB_API_KEY=...
PEERINGDB_BASE_URL=https://www.peeringdb.com/api

# DuckDB
DUCKDB_PATH=data/pdbq.duckdb

# Query history
QUERY_HISTORY_PATH=data/query_history.jsonl
QUERY_HISTORY_MAX_ENTRIES=10000  # rotate after this many entries, 0 = unlimited

# Auth (simple API key gate for the FastAPI backend)
# Comma-separated list of valid API keys
PDBQ_API_KEYS=changeme-key-1,changeme-key-2

# Admin key for /sync/trigger endpoint
ADMIN_API_KEY=changeme-admin-key

# Google OAuth (for Sheets export)
# Path to OAuth client secrets JSON downloaded from Google Cloud Console
GOOGLE_CLIENT_SECRETS_PATH=secrets/google_client_secrets.json
# Where to store OAuth tokens per user
GOOGLE_TOKEN_STORE_PATH=data/google_tokens/

# CORS allowed origins (comma-separated, production only)
ALLOWED_ORIGINS=https://yourdomain.com

# Environment
ENVIRONMENT=development  # development | production
